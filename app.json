{
  "expo": {
    "name": "FarmEzy",
    "slug": "farmezy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/farmezy.png",
    "scheme": "tempapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/farmezy.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aadiichavan.farmezy"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/farmezy.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.aadiichavan.farmezy"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/farmezy.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "69915e90-4e23-4aef-bde8-518fd6d8af2e"
      }
    },
    "owner": "aadiichavan"
  }
}
